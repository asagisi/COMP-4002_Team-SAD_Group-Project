{
  "name": "package",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "apps/backend",
    "apps/frontend"
  ],
  "scripts": {
    "start:frontend": "npm run dev --workspace=@team-sad/frontend",
    "start:backend": "npm start --workspace=@team-sad/backend",
    "dev": "concurrently \"npm run start:frontend\" \"npm run start:backend\"",
    "build": "npm run build --workspace=@team-sad/frontend",
    "lint": "npm run lint --workspace=@team-sad/frontend",
    "preview": "npm run preview --workspace=@team-sad/frontend"
  },
  "dependencies": {
    "dotenv": "^16.6.1",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "typescript": "~5.9.3"
  }
}
